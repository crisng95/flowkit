{
  "manifest_version": 3,
  "name": "Flow Kit",
  "version": "0.2.0",
  "description": "Local agent bridge for Google Flow API — captures tokens, solves reCAPTCHA, proxies API calls",
  "permissions": ["storage", "alarms", "tabs", "activeTab", "webRequest", "scripting", "declarativeNetRequest"],
  "host_permissions": [
    "<all_urls>",
    "https://labs.google/*",
    "https://flow.google.com/*",
    "https://*.flow.google.com/*",
    "https://*.google/*",
    "https://accounts.google.com/*",
    "https://*.google.com/*",
    "https://www.gstatic.com/*",
    "https://*.gstatic.com/*",
    "https://recaptcha.net/*",
    "https://*.recaptcha.net/*",
    "https://aisandbox-pa.googleapis.com/*",
    "http://127.0.0.1:8100/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://labs.google/*",
        "https://*.labs.google/*",
        "https://flow.google.com/*",
        "https://*.flow.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": [
        "https://labs.google/*",
        "https://*.labs.google/*",
        "https://flow.google.com/*",
        "https://*.flow.google.com/*"
      ]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "referer_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "side_panel": {
    "default_path": "side_panel.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Flow Kit"
  }
}
